# Copy this file to .env for local development (never commit the real .env).

# Gemini API key — get one at https://aistudio.google.com/apikey
# In production (Cloud Run) this is injected from Secret Manager instead.
GEMINI_API_KEY=your-gemini-api-key-here

# The one origin allowed to call this API (your Vercel site URL).
ALLOWED_ORIGIN=http://localhost:3000

# Port to listen on. Cloud Run sets this automatically in production.
PORT=8080

# Optional: max total /chat requests served per calendar day (default 400).
DAILY_LIMIT=400
